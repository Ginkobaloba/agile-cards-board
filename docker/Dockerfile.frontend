# Builds the React app and serves the static output through nginx.
# Nginx also proxies /api and /events to the backend container.

FROM node:20-alpine AS build
WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

COPY frontend/. ./
RUN npm run build

# ----- runtime -----

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
